# Backend env — copy to Railway "backend" service Variables (do NOT commit a real .env).

# ── LLM provider ──────────────────────────────
VC_LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
VC_DEEPSEEK_MODEL=deepseek-v4-flash

# ── Product pool: seed dir + persistent DB on the Railway volume ──
# 조합은 반드시 짝으로: seed_amazon+/data/amazon_ko.db (현 프로덕션, Amazon KO 600)
#                    | seed_naver+/data/nv_study.db (NAVER 600, 과거 스터디 데이터)
VC_SEED_DIR=seed_amazon
VC_DB_PATH=/data/amazon_ko.db
VC_EXPORT_DIR=/data/exports

# ── 스터디 분리 (2026-07-02) — 라이브 참가자 배포 전용 ──
# study: simulations/synthesis/pscon 라우터 미마운트(404) — 스터디 DB에 시뮬 데이터 유입 차단.
# research/exports API는 아래 키 요구(403). 로컬 개발은 둘 다 비워둔다(전부 개방).
VC_APP_MODE=study
VC_RESEARCH_KEY=

# ── CORS: the frontend's public origin (belt-and-suspenders; rewrites proxy is server-side) ──
VC_CORS_ORIGINS=https://<your-frontend>.up.railway.app

# ── (optional) Naver Search API — only for the offline image-enrichment script ──
VC_NAVER_CLIENT_ID=
VC_NAVER_CLIENT_SECRET=

# ── (optional) OpenAI fallback provider ───────
# OPENAI_API_KEY=
# VC_OPENAI_MODEL=gpt-5-nano
