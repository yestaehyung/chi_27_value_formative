# ── Secrets / env ─────────────────────────────
.env
.env.*
!.env.example

# ── Local SQLite (prod DB lives on the Railway volume) ──
*.db
*.db-wal
*.db-shm

# ── Python ────────────────────────────────────
.venv/
__pycache__/
*.pyc
.pytest_cache/

# ── Node / Next.js ────────────────────────────
node_modules/
.next/
out/
*.tsbuildinfo
next-env.d.ts

# ── Runtime-generated research output (belongs on the volume) ──
backend/exports/

# ── Snapshot/backup files (the live file is canonical; *.db already ignored) ──
*.bak*
*~

# ── Regenerable research artifacts (not needed for the participant-study deploy) ──
backend/data/

# ── Research proposal doc (not deployable code, 6.4MB) ──
*.pdf

# ── ETL intermediates (not loaded at runtime — merged into products.json) ──
backend/seed_naver/category_reclassified.json
backend/seed_naver/fashion_reclassified.json
backend/seed_naver/synthetic_products.json
backend/seed_naver/scenarios_electronics_draft.json
backend/seed_naver/product_descriptions.json
backend/seed_naver/products_naver.json

# ── Logs / OS ─────────────────────────────────
*.log
.DS_Store
